# ─────────────────────────────────────────────────────────────────────────────
# Flat (legacy) format — single account only.
# Every variable maps directly to its property name.
# ─────────────────────────────────────────────────────────────────────────────

ImmichServerUrl=URL

# Either ApiKey or ApiKeyFile must be specified.
ApiKey=KEY
# ApiKeyFile=/path/to/key

# AuthenticationSecret=
# Interval=45
# TransitionDuration=2
# ImageZoom=true
# ImagePan=false
# ImageFill=false
# PlayAudio=false
# SnapAudio=false
# SnapserverUrl=
# Layout=splitview
# DownloadImages=false
# ShowMemories=false
# ShowFavorites=false
# ShowArchived=false
# ShowVideos=false
# ImagesFromDays=
# ImagesFromDate=
# ImagesUntilDate=
# RenewImagesDuration=30
# Rating=5
# Albums=ALBUM1,ALBUM2
# ExcludedAlbums=ALBUM3,ALBUM4
# People=PERSON1,PERSON2
# Tags=Vacation,Travel/Europe
# Webcalendars=https://calendar.google.com/calendar/ical/XXXXXX/public/basic.ics
# RefreshAlbumPeopleInterval=12
# ShowClock=true
# ClockFormat=hh:mm
# ClockDateFormat=eee, MMM d
# ShowProgressBar=true
# ShowPhotoDate=true
# PhotoDateFormat=yyyy-MM-dd
# ShowImageDesc=true
# ShowPeopleDesc=true
# ShowTagsDesc=true
# ShowAlbumName=true
# ShowImageLocation=true
# ImageLocationFormat=City,State,Country
# PrimaryColor=#F5DEB3
# SecondaryColor=#000000
# Style=none
# BaseFontSize=17px
# WeatherApiKey=
# ShowWeatherDescription=true
# WeatherIconUrl=https://openweathermap.org/img/wn/{IconId}.png
# UnitSystem=imperial
# WeatherLatLong=
# Language=en
# Webhook=


# ─────────────────────────────────────────────────────────────────────────────
# Namespaced format — supports multiple accounts.
# Use General__ prefix for display/behaviour settings and
# Accounts__N__ (0-based index) for each Immich account.
# When any General__ or Accounts__ variable is present this format takes
# priority and the flat variables above are ignored.
# ─────────────────────────────────────────────────────────────────────────────

# General__AuthenticationSecret=
# General__Interval=45
# General__TransitionDuration=2
# General__RenewImagesDuration=30
# General__RefreshAlbumPeopleInterval=12
# General__Language=en
# General__Layout=splitview
# General__DownloadImages=false
# General__ShowClock=true
# General__ClockFormat=hh:mm
# General__ClockDateFormat=eee, MMM d
# General__ShowProgressBar=true
# General__ShowPhotoDate=true
# General__PhotoDateFormat=yyyy-MM-dd
# General__ShowImageDesc=true
# General__ShowPeopleDesc=true
# General__ShowTagsDesc=true
# General__ShowAlbumName=true
# General__ShowImageLocation=true
# General__ImageLocationFormat=City,State,Country
# General__PrimaryColor=#F5DEB3
# General__SecondaryColor=#000000
# General__Style=none
# General__BaseFontSize=17px
# General__ImageZoom=true
# General__ImagePan=false
# General__ImageFill=false
# General__PlayAudio=false
# General__SnapAudio=false
# General__SnapserverUrl=
# General__WeatherApiKey=
# General__ShowWeatherDescription=true
# General__WeatherIconUrl=https://openweathermap.org/img/wn/{IconId}.png
# General__UnitSystem=imperial
# General__WeatherLatLong=
# General__Webhook=
# General__Webcalendars=https://calendar.google.com/calendar/ical/XXXXXX/public/basic.ics,https://other.ics

# Account 0
# Accounts__0__ImmichServerUrl=https://immich.example.com
# Accounts__0__ApiKey=KEY
# Accounts__0__ApiKeyFile=/path/to/key
# Accounts__0__ShowMemories=false
# Accounts__0__ShowFavorites=false
# Accounts__0__ShowArchived=false
# Accounts__0__ShowVideos=false
# Accounts__0__ImagesFromDays=
# Accounts__0__ImagesFromDate=
# Accounts__0__ImagesUntilDate=
# Accounts__0__Albums=UUID1,UUID2
# Accounts__0__ExcludedAlbums=UUID3
# Accounts__0__People=UUID4,UUID5
# Accounts__0__Tags=Vacation,Travel/Europe
# Accounts__0__Rating=

# Account 1 (add more by incrementing the index)
# Accounts__1__ImmichServerUrl=https://immich2.example.com
# Accounts__1__ApiKey=KEY2
